{
  "mainClass"     : "Integrator",
  "baseClasses"   : [],
  "baseDirectory" : "../..",
  "composClasses" : [{"interface" : "ISceneObject", 
                      "implementation": "BVHRT"}],
  "source"         : ["HydraCore3/integrator_pt.cpp", 
                      "HydraCore3/integrator_pt_lgt.cpp", 
                      "HydraCore3/integrator_pt_mat.cpp",
                      "HydraCore3/integrator_rt.cpp",
                      "HydraCore3/integrator_spectrum.cpp",
                      "MultiRenderer/BVH2Common.cpp"],
  "includeProcess" : [".", "MultiRenderer", "HydraCore3/cam_plugin"],
  "includeIgnore"  : ["dependencies/1st-party/LiteMath", "LiteScene"],
  "options" : {
        "-pattern"    : "rtv",
        "-shaderCC"   : "glsl",
        "-shaderFolderPrefix" : "",
        "-suffix" : "_glsl_litert",
        "-megakernel" : 1,
        "-const_ubo"  : 1,
        "-const_shit" : 1,
        "-enable_ray_tracing_pipeline" : 0,
        "-enable_motion_blur"          : 0,
        "end" : ""
  },

  "kernels" : {
    "all"        : {"nonConstantData": {"out_color"  : 1, "m_randomGens" : 1}},
    "PackXYMega" : {"nonConstantData": {"m_packedXY" : 1}}
  },

  "defines" : {
    "KERNEL_SLICER"    : "1",
    "DISABLE_LENS"     : "1",
    "DISABLE_SPECTRUM" : "1",
    "LITERT_RENDERER"  : "1",
    "DISABLE_OPENVDB"  : "1",
    "DISABLE_CSGDNF"   : "1",
    "DISABLE_SDF_GRID" : "1",
    "DISABLE_SDF_FRAME_OCTREE_TEX" : "1",
    "DISABLE_GRAPHICS_PRIM" : "1"
  },
  "end" : ""
}